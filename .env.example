# ══════════════════════════════════════════════════════════
# Aria — Configuration
# Copy to .env and customize as needed.
# ══════════════════════════════════════════════════════════

# App
APP_NAME=Aria
DEBUG=false

# Ollama (local AI model server)
OLLAMA_BASE_URL=http://localhost:11434

# Model assignments — change based on your hardware
# For 8GB RAM laptops, use smaller models:
#   MODEL_CHAT=phi4-mini
#   MODEL_REASONING=phi4-mini
#   MODEL_CODE=qwen2.5-coder:1.5b
# For 16GB+ RAM:
MODEL_CHAT=llama3.2
MODEL_REASONING=llama3.2
MODEL_CODE=qwen2.5-coder
MODEL_VISION=llava
MODEL_EMBEDDING=nomic-embed-text
MODEL_SMALL=phi4-mini

# Voice
VOICE_ENABLED=true
STT_MODEL=whisper-base

# Web search (SearXNG — auto-started via Docker)
SEARXNG_URL=http://localhost:8888

# Search provider: searxng (default) or tavily
# SEARCH_PROVIDER=searxng
# Tavily API key (optional — enables Tavily as a search provider)
# Get your key at https://app.tavily.com
# TAVILY_API_KEY=tvly-YOUR_API_KEY

# Optional: Cloud API fallback (leave empty to use local only)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
