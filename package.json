{
  "name": "aria",
  "version": "0.1.0",
  "description": "Aria — AI Personal Assistant Desktop App",
  "main": "electron/main.js",
  "scripts": {
    "electron:dev": "NODE_ENV=development concurrently --kill-others --names \"frontend,electron\" \"npm run frontend:dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run frontend:build && electron-builder --dir",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build"
  },
  "build": {
    "appId": "com.aria.assistant",
    "productName": "Aria",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*", "!venv/**", "!*.log", "!__pycache__/**", "!**/*.pyc"]
      }
    ],
    "linux": { "target": "AppImage" },
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0"
  }
}
